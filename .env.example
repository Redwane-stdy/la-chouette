# =============================================================================
# La Chouette — Variables d'environnement
# Copiez ce fichier en .env : cp .env.example .env
# =============================================================================

# --- Kafka ---
KAFKA_BROKERS=kafka:9092

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lachouette
POSTGRES_PASSWORD=secret
POSTGRES_DB=lachouette
# DSN pour les services Go (lib/pq)
POSTGRES_DSN=postgres://lachouette:secret@postgres:5432/lachouette?sslmode=disable
# DSN pour les services C# (Npgsql)
POSTGRES_NPGSQL_DSN=Host=postgres;Port=5432;Username=lachouette;Password=secret;Database=lachouette;

# --- Problème mathématique (ignoré si DEMO_MODE=true) ---
NUM_UNKNOWNS=50         # Nombre d'inconnues (x1...xN)
NUM_EQUATIONS=80        # Nombre d'équations générées (recommandé : 1.5× à 2× NUM_UNKNOWNS)

# --- Mode démonstration ---
# true  → 15 inconnues, 25 équations, intervalles ÷3, durée ~60s
# false → NUM_UNKNOWNS/NUM_EQUATIONS ci-dessus, durée variable
DEMO_MODE=true

# --- Intervalles des sources (millisecondes) ---
SOURCE_ALPHA_INTERVAL_MS=3000
SOURCE_BETA_INTERVAL_MS=4000
SOURCE_GAMMA_INTERVAL_MS=5000
SOURCE_NOISE_INTERVAL_MIN_MS=2000
SOURCE_NOISE_INTERVAL_MAX_MS=7000

# --- API ---
API_PORT=8080

# --- Dashboard ---
DASHBOARD_PORT=3000

# --- Logs ---
LOG_LEVEL=INFO   # DEBUG | INFO | WARN | ERROR
